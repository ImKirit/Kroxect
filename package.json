{
  "name": "krate",
  "productName": "Krate",
  "version": "1.2.0",
  "description": "Local-first project organizer with tags, folder templates, file nicknames and a global quick-search overlay.",
  "author": "ImKirit <main@kirit.xyz>",
  "license": "MIT",
  "homepage": "https://imkirit.dev/krate",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImKirit/Krate.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "icon": "node scripts/make-icon.js",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.imkirit.krate",
    "productName": "Krate",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "protocols": [
      {
        "name": "Krate Project Link",
        "schemes": ["krate"]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Krate"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3"
  }
}
